const state = {
  page: 1,
  pages: 1,
  filters: {},
  userPage: 1,
  userPages: 1,
  userQuery: "",
  detailRaw: false,       // toggle raw json vs structured view
  detailEntry: null,      // cached detail entry
};

const nodes = {
  downstreamUrl: document.getElementById("downstreamUrl"),
  queueSize: document.getElementById("queueSize"),
  statsCards: document.getElementById("statsCards"),
  providerList: document.getElementById("providerList"),
  statusList: document.getElementById("statusList"),
  searchForm: document.getElementById("searchForm"),
  logRows: document.getElementById("logRows"),
  logMeta: document.getElementById("logMeta"),
  detailPane: document.getElementById("detailPane"),
  toggleRawBtn: document.getElementById("toggleRawBtn"),
  pageInfo: document.getElementById("pageInfo"),
  prevPage: document.getElementById("prevPage"),
  nextPage: document.getElementById("nextPage"),
  refreshOverview: document.getElementById("refreshOverview"),
  // 用户管理
  createUserBtn: document.getElementById("createUserBtn"),
  userSearch: document.getElementById("userSearch"),
  userMeta: document.getElementById("userMeta"),
  userRows: document.getElementById("userRows"),
  userPageInfo: document.getElementById("userPageInfo"),
  userPrevPage: document.getElementById("userPrevPage"),
  userNextPage: document.getElementById("userNextPage"),
  // 对话框
  userDialog: document.getElementById("userDialog"),
  dialogTitle: document.getElementById("dialogTitle"),
  fieldUserId: document.getElementById("fieldUserId"),
  fieldName: document.getElementById("fieldName"),
  fieldApiKey: document.getElementById("fieldApiKey"),
  fieldDownstreamUrl: document.getElementById("fieldDownstreamUrl"),
  fieldDownstreamApikey: document.getElementById("fieldDownstreamApikey"),
  fieldNotes: document.getElementById("fieldNotes"),
  fieldEnabled: document.getElementById("fieldEnabled"),
  genApiKeyBtn: document.getElementById("genApiKeyBtn"),
  dialogCancelBtn: document.getElementById("dialogCancelBtn"),
  dialogSubmitBtn: document.getElementById("dialogSubmitBtn"),
};

function escapeHtml(value) {
  return String(value)
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

async function fetchJSON(url, options) {
  const response = await fetch(url, options);
  const text = await response.text();
  let payload;
  try {
    payload = JSON.parse(text);
  } catch {
    throw new Error(`接口返回了非 JSON 内容: ${text.slice(0, 200)}`);
  }
  if (!response.ok) {
    throw new Error(payload.detail || `请求失败: ${response.status}`);
  }
  return payload;
}

function formatTime(timestamp) {
  if (!timestamp) {
    return "-";
  }
  return new Date(timestamp * 1000).toLocaleString("zh-CN");
}

function formatMs(value) {
  if (value === null || value === undefined) {
    return "-";
  }
  return `${value.toFixed(1)} ms`;
}

function statCard(label, value) {
  return `<article class="stat"><span>${label}</span><strong>${value}</strong></article>`;
}

function renderChips(container, items, formatter) {
  if (!items.length) {
    container.innerHTML = '<span>暂无数据</span>';
    return;
  }
  container.innerHTML = items.map((item) => formatter(item)).join("");
}

async function loadOverview() {
  const payload = await fetchJSON("/admin/api/overview");
  const totals = payload.data.totals || {};
  nodes.downstreamUrl.textContent = payload.downstream_url || "-";
  nodes.queueSize.textContent = payload.queue_size ?? 0;
  nodes.statsCards.innerHTML = [
    statCard("总请求数", totals.total_requests ?? 0),
    statCard("流式请求", totals.stream_requests ?? 0),
    statCard("错误请求", totals.error_requests ?? 0),
    statCard("Provider 数", totals.providers ?? 0),
    statCard("模型数", totals.models ?? 0),
    statCard("最后请求", formatTime(totals.latest_request_at)),
  ].join("");

  renderChips(nodes.providerList, payload.data.providers || [], (item) => {
    return `<div class="chip"><strong>${escapeHtml(item.provider)}</strong><span> ${item.count}</span></div>`;
  });
  renderChips(nodes.statusList, payload.data.statuses || [], (item) => {
    return `<div class="chip"><strong>${escapeHtml(item.status)}</strong><span> ${item.count}</span></div>`;
  });
}

function buildQuery(params) {
  const query = new URLSearchParams();
  Object.entries(params).forEach(([key, value]) => {
    if (value !== "" && value !== null && value !== undefined) {
      query.set(key, String(value));
    }
  });
  return query.toString();
}

async function loadLogs() {
  const query = buildQuery({ ...state.filters, page: state.page });
  const payload = await fetchJSON(`/admin/api/logs?${query}`);
  const { items, pagination } = payload;
  state.pages = pagination.pages;
  nodes.pageInfo.textContent = `第 ${pagination.page} / ${pagination.pages} 页`;
  nodes.logMeta.textContent = `共 ${pagination.total} 条记录，当前每页 ${pagination.page_size} 条。`;
  nodes.prevPage.disabled = pagination.page <= 1;
  nodes.nextPage.disabled = pagination.page >= pagination.pages;

  if (!items.length) {
    nodes.logRows.innerHTML = '<tr><td colspan="7">没有符合条件的日志。</td></tr>';
    return;
  }

  nodes.logRows.innerHTML = items.map((item) => {
    const badgeClass = item.response_status >= 400 ? "badge error" : "badge";
    const model = escapeHtml(item.request_model || "-");
    const streamIcon = item.request_stream ? " ⚡" : "";
    return `
      <tr data-id="${item.id}">
        <td>${formatTime(item.created_at)}</td>
        <td>${escapeHtml(item.provider)}</td>
        <td>${model}${streamIcon}</td>
        <td>${escapeHtml(item.method)}</td>
        <td><span class="${badgeClass}">${item.response_status ?? "-"}</span></td>
        <td>${formatMs(item.duration_ms)}</td>
        <td>${escapeHtml(item.preview || "-")}</td>
      </tr>
    `;
  }).join("");
}

async function loadDetail(logId) {
  const entry = await fetchJSON(`/admin/api/logs/${logId}`);
  state.detailEntry = entry;
  state.detailRaw = false;
  nodes.toggleRawBtn.style.display = "";
  nodes.toggleRawBtn.textContent = "原始 JSON";
  renderStructuredDetail(entry);
}

// ═══════════════════════════════════════════════════
// 结构化对话详情渲染
// ═══════════════════════════════════════════════════

function parseSSEChunks(raw) {
  if (typeof raw !== "string") return null;
  const lines = raw.split("\n");
  let reasoning = "";
  let content = "";
  let model = "";
  let finishReason = "";
  let usage = null;
  let toolCalls = [];
  for (const line of lines) {
    if (!line.startsWith("data: ")) continue;
    const payload = line.slice(6).trim();
    if (payload === "[DONE]") continue;
    try {
      const chunk = JSON.parse(payload);
      if (chunk.model) model = chunk.model;
      if (chunk.usage) usage = chunk.usage;
      const choices = chunk.choices || [];
      for (const c of choices) {
        if (c.finish_reason) finishReason = c.finish_reason;
        const delta = c.delta || {};
        if (delta.reasoning_content) reasoning += delta.reasoning_content;
        if (delta.content) content += delta.content;
        if (delta.tool_calls) {
          for (const tc of delta.tool_calls) {
            const idx = tc.index ?? toolCalls.length;
            if (!toolCalls[idx]) toolCalls[idx] = { id: "", type: "function", function: { name: "", arguments: "" } };
            if (tc.id) toolCalls[idx].id = tc.id;
            if (tc.type) toolCalls[idx].type = tc.type;
            if (tc.function) {
              if (tc.function.name) toolCalls[idx].function.name += tc.function.name;
              if (tc.function.arguments) toolCalls[idx].function.arguments += tc.function.arguments;
            }
          }
        }
      }
    } catch {}
  }
  return { reasoning, content, model, finishReason, usage, toolCalls: toolCalls.length ? toolCalls : null };
}

function getResponseData(entry) {
  const rb = entry.response_body;
  // Non-streaming JSON response
  if (rb && typeof rb === "object") {
    const choice = (rb.choices || [])[0];
    const msg = choice?.message || {};
    return {
      reasoning: msg.reasoning_content || "",
      content: msg.content || "",
      model: rb.model || "",
      finishReason: choice?.finish_reason || "",
      usage: rb.usage || null,
      toolCalls: msg.tool_calls || null,
    };
  }
  // Streaming SSE response
  if (typeof rb === "string") {
    return parseSSEChunks(rb);
  }
  return null;
}

function summaryItem(label, value, cls) {
  const vClass = cls ? ` ${cls}` : "";
  return `<div class="item"><span class="label">${escapeHtml(label)}</span><span class="value${vClass}">${escapeHtml(String(value))}</span></div>`;
}

function renderTokenSection(usage) {
  if (!usage) return "";
  const prompt = usage.prompt_tokens ?? 0;
  const completion = usage.completion_tokens ?? 0;
  const total = usage.total_tokens || (prompt + completion);
  const reasoning = usage.completion_tokens_details?.reasoning_tokens ?? 0;
  const cached = usage.prompt_tokens_details?.cached_tokens ?? 0;
  const actualPrompt = prompt - cached;
  const actualCompletion = completion - reasoning;

  // Build bar segments
  const segments = [];
  if (total > 0) {
    if (cached > 0) segments.push({ cls: "cached", pct: (cached / total * 100), label: `缓存 ${cached}` });
    if (actualPrompt > 0) segments.push({ cls: "prompt", pct: (actualPrompt / total * 100), label: `Prompt ${actualPrompt}` });
    if (reasoning > 0) segments.push({ cls: "reasoning", pct: (reasoning / total * 100), label: `推理 ${reasoning}` });
    if (actualCompletion > 0) segments.push({ cls: "completion", pct: (actualCompletion / total * 100), label: `输出 ${actualCompletion}` });
  }

  const barHtml = segments.map(s =>
    `<div class="token-bar-seg ${s.cls}" style="width:${Math.max(s.pct, 2).toFixed(1)}%" title="${s.label}">${s.pct > 10 ? s.label : ""}</div>`
  ).join("");

  const items = [
    `<div class="token-item"><span class="token-dot prompt"></span>Prompt 输入<strong>${prompt}</strong></div>`,
  ];
  if (cached > 0) {
    items.push(`<div class="token-item"><span class="token-dot cached"></span>缓存命中<strong>${cached}</strong></div>`);
  }
  items.push(`<div class="token-item"><span class="token-dot completion"></span>Completion 输出<strong>${completion}</strong></div>`);
  if (reasoning > 0) {
    items.push(`<div class="token-item"><span class="token-dot reasoning"></span>推理 Token<strong>${reasoning}</strong></div>`);
  }
  items.push(`<div class="token-item"><strong style="font-size:15px">总计 ${total}</strong></div>`);
  if (cached > 0) {
    const hitRate = ((cached / prompt) * 100).toFixed(1);
    items.push(`<div class="token-item">缓存命中率<strong>${hitRate}%</strong></div>`);
  }

  return `
    <div class="token-section">
      <h4>Token 用量</h4>
      <div class="token-bar-wrap">${barHtml}</div>
      <div class="token-grid">${items.join("")}</div>
    </div>
  `;
}

function renderMessageItem(msg, index, total, defaultOpen) {
  const role = msg.role || "unknown";
  const collapsed = defaultOpen ? "" : " collapsed";
  let bodyHtml = "";
  let meta = "";

  const content = msg.content;
  if (typeof content === "string") {
    const charCount = content.length;
    meta = `${charCount} 字符`;
    bodyHtml = `<div class="msg-body">${escapeHtml(content)}</div>`;
  } else if (Array.isArray(content)) {
    // Multi-part content (text + images)
    const parts = content.map(p => {
      if (p.type === "text") return escapeHtml(p.text || "");
      if (p.type === "image_url") return `[图片: ${escapeHtml(p.image_url?.url?.slice(0, 60) || "...")}]`;
      return escapeHtml(JSON.stringify(p));
    }).join("\n\n");
    meta = `${content.length} 部分`;
    bodyHtml = `<div class="msg-body">${parts}</div>`;
  } else if (content === null || content === undefined) {
    // Tool call message (no text content)
    if (msg.tool_calls) {
      const tcJson = JSON.stringify(msg.tool_calls, null, 2);
      meta = `${msg.tool_calls.length} 个工具调用`;
      bodyHtml = `<div class="msg-body-json">${escapeHtml(tcJson)}</div>`;
    } else if (msg.function_call) {
      const fcJson = JSON.stringify(msg.function_call, null, 2);
      meta = "函数调用";
      bodyHtml = `<div class="msg-body-json">${escapeHtml(fcJson)}</div>`;
    } else {
      bodyHtml = `<div class="msg-body hint">（空）</div>`;
    }
  } else {
    bodyHtml = `<div class="msg-body-json">${escapeHtml(JSON.stringify(content, null, 2))}</div>`;
  }

  // Add tool_call_id or name if present
  let extraMeta = "";
  if (msg.tool_call_id) extraMeta += `tool_call_id: ${msg.tool_call_id}`;
  if (msg.name) extraMeta += (extraMeta ? " | " : "") + `name: ${msg.name}`;
  if (extraMeta) meta = meta ? `${meta} · ${extraMeta}` : extraMeta;

  const posLabel = total > 1 ? `#${index + 1}` : "";

  return `
    <div class="msg-item${collapsed}" onclick="this.classList.toggle('collapsed')">
      <div class="msg-head">
        <span class="msg-role ${role}">${role}</span>
        <span class="msg-meta">${posLabel}${meta ? (posLabel ? " · " : "") + meta : ""}</span>
        <span class="msg-toggle">▼</span>
      </div>
      ${bodyHtml}
    </div>
  `;
}

function renderMessagesSection(messages) {
  if (!messages || !messages.length) return "";
  // Categorize messages
  const system = messages.filter(m => m.role === "system");
  const history = messages.slice(0, -1).filter(m => m.role !== "system");
  const lastMsg = messages[messages.length - 1];
  const isLastUser = lastMsg.role === "user";

  let html = '<div class="msg-section"><h4>请求消息</h4><div class="msg-list">';

  // System messages (expanded by default)
  for (const msg of system) {
    html += renderMessageItem(msg, 0, 1, true);
  }

  // History messages (collapsed by default)
  if (history.length > 0) {
    for (let i = 0; i < history.length; i++) {
      html += renderMessageItem(history[i], i, history.length, false);
    }
  }

  // Final user prompt (expanded by default)
  if (isLastUser) {
    html += renderMessageItem(lastMsg, messages.length - 1, messages.length, true);
  } else if (lastMsg.role !== "system" && !history.includes(lastMsg)) {
    html += renderMessageItem(lastMsg, messages.length - 1, messages.length, true);
  }

  html += '</div></div>';
  return html;
}

function renderToolsSection(tools) {
  if (!tools || !tools.length) return "";
  let html = '<div class="collapsible"><div class="collapsible-head" onclick="this.parentElement.classList.toggle(\'closed\')"><span class="collapsible-arrow">▼</span>工具定义 (' + tools.length + ')</div><div class="collapsible-body"><div class="tools-grid" style="padding:10px">';
  for (const tool of tools) {
    const fn = tool.function || tool;
    const name = fn.name || "(unnamed)";
    const desc = fn.description || "";
    const params = fn.parameters ? JSON.stringify(fn.parameters, null, 2) : "";
    html += `
      <div class="tool-card collapsed" onclick="event.stopPropagation();this.classList.toggle('collapsed')">
        <div class="tool-card-head">
          <span class="tool-name">${escapeHtml(name)}</span>
          <span class="tool-desc">${escapeHtml(desc.slice(0, 80))}</span>
        </div>
        ${params ? `<div class="tool-card-body">${escapeHtml(params)}</div>` : ""}
      </div>
    `;
  }
  html += '</div></div></div>';
  return html;
}

function renderResponseSection(respData) {
  if (!respData) return "";
  let html = '<div class="response-section"><h4>模型回复</h4>';

  if (respData.reasoning) {
    html += `
      <div class="reasoning-block">
        <div class="reasoning-label">💭 推理过程</div>
        ${escapeHtml(respData.reasoning)}
      </div>`;
  }

  if (respData.content) {
    html += `<div class="content-block">${escapeHtml(respData.content)}</div>`;
  }

  // Tool calls in response
  if (respData.toolCalls && respData.toolCalls.length) {
    html += '<div style="margin-top:10px"><strong style="font-size:13px">工具调用:</strong>';
    for (const tc of respData.toolCalls) {
      const fn = tc.function || {};
      let argsPretty = fn.arguments || "";
      try { argsPretty = JSON.stringify(JSON.parse(argsPretty), null, 2); } catch {}
      html += `<div class="tool-card" style="margin-top:6px">
        <div class="tool-card-head"><span class="tool-name">${escapeHtml(fn.name || "")}</span></div>
        <div class="tool-card-body">${escapeHtml(argsPretty)}</div>
      </div>`;
    }
    html += '</div>';
  }

  if (respData.finishReason) {
    html += `<div style="margin-top:8px;font-size:12px;color:var(--muted)">finish_reason: ${escapeHtml(respData.finishReason)}</div>`;
  }

  html += '</div>';
  return html;
}

function renderHeadersCollapsible(title, headers) {
  if (!headers || !Object.keys(headers).length) return "";
  const rows = Object.entries(headers).map(([k, v]) =>
    `<tr><td>${escapeHtml(k)}</td><td>${escapeHtml(String(v))}</td></tr>`
  ).join("");
  return `
    <div class="collapsible closed">
      <div class="collapsible-head" onclick="this.parentElement.classList.toggle('closed')">
        <span class="collapsible-arrow">▼</span>${title} (${Object.keys(headers).length})
      </div>
      <div class="collapsible-body">
        <table class="header-table">${rows}</table>
      </div>
    </div>`;
}

function renderRequestParams(body) {
  if (!body || typeof body !== "object") return "";
  const skip = new Set(["messages", "tools", "functions", "tool_choice", "function_call"]);
  const params = Object.entries(body).filter(([k]) => !skip.has(k));
  if (!params.length) return "";

  const items = params.map(([k, v]) => {
    let display = v;
    if (typeof v === "object" && v !== null) display = JSON.stringify(v);
    return `<div class="param-item"><div class="param-label">${escapeHtml(k)}</div><div class="param-value">${escapeHtml(String(display))}</div></div>`;
  }).join("");

  return `
    <div class="collapsible">
      <div class="collapsible-head" onclick="this.parentElement.classList.toggle('closed')">
        <span class="collapsible-arrow">▼</span>请求参数
      </div>
      <div class="collapsible-body">
        <div class="params-grid">${items}</div>
      </div>
    </div>`;
}

function renderStructuredDetail(entry) {
  const pane = nodes.detailPane;
  pane.className = "";

  const respData = getResponseData(entry);
  const usage = respData?.usage || null;

  const reqBody = entry.request_body;
  const messages = (reqBody && typeof reqBody === "object") ? reqBody.messages : null;
  const tools = (reqBody && typeof reqBody === "object") ? (reqBody.tools || reqBody.functions) : null;

  const isStream = reqBody?.stream ? "是" : "否";
  const statusCls = (entry.response_status >= 400) ? "err" : "ok";

  let html = "";

  // 1) 概览卡片
  html += '<div class="detail-summary">';
  html += summaryItem("模型", entry.request_body?.model || respData?.model || "-");
  html += summaryItem("状态", entry.response_status ?? "-", statusCls);
  html += summaryItem("耗时", formatMs(entry.duration_ms));
  html += summaryItem("流式", isStream);
  html += summaryItem("Provider", entry.provider || "-");
  html += summaryItem("客户端", entry.client || "-");
  if (entry.user_name) html += summaryItem("用户", entry.user_name);
  html += summaryItem("响应大小", entry.response_size ? `${(entry.response_size / 1024).toFixed(1)} KB` : "-");
  html += summaryItem("时间", formatTime(entry.timestamp));
  html += '</div>';

  // 2) Token 用量
  html += renderTokenSection(usage);

  // 3) 请求消息
  html += renderMessagesSection(messages);

  // 4) 请求参数 (model, stream, temperature, etc.)
  html += renderRequestParams(reqBody);

  // 5) 工具定义
  html += renderToolsSection(tools);

  // 6) 模型回复
  html += renderResponseSection(respData);

  // 7) 请求/响应头
  html += renderHeadersCollapsible("请求头", entry.request_headers);
  html += renderHeadersCollapsible("响应头", entry.response_headers);

  pane.innerHTML = html;
}

function renderRawDetail(entry) {
  const pane = nodes.detailPane;
  pane.className = "";
  pane.innerHTML = `<pre class="detail-raw-json">${escapeHtml(JSON.stringify(entry, null, 2))}</pre>`;
}

// Toggle raw / structured view
nodes.toggleRawBtn.addEventListener("click", () => {
  if (!state.detailEntry) return;
  state.detailRaw = !state.detailRaw;
  if (state.detailRaw) {
    nodes.toggleRawBtn.textContent = "结构化视图";
    renderRawDetail(state.detailEntry);
  } else {
    nodes.toggleRawBtn.textContent = "原始 JSON";
    renderStructuredDetail(state.detailEntry);
  }
});

nodes.searchForm.addEventListener("submit", async (event) => {
  event.preventDefault();
  const formData = new FormData(nodes.searchForm);
  state.page = 1;
  state.filters = {
    q: formData.get("q") || "",
    provider: formData.get("provider") || "",
    model: formData.get("model") || "",
    status: formData.get("status") || "",
    method: formData.get("method") || "",
    stream: formData.get("stream") || "",
  };
  await loadLogs();
});

nodes.logRows.addEventListener("click", async (event) => {
  const row = event.target.closest("tr[data-id]");
  if (!row) {
    return;
  }
  // Highlight selected row
  nodes.logRows.querySelectorAll("tr.selected").forEach(r => r.classList.remove("selected"));
  row.classList.add("selected");
  await loadDetail(row.dataset.id);
  document.getElementById("detailSection").scrollIntoView({ behavior: "smooth", block: "start" });
});

nodes.prevPage.addEventListener("click", async () => {
  if (state.page > 1) {
    state.page -= 1;
    await loadLogs();
  }
});

nodes.nextPage.addEventListener("click", async () => {
  if (state.page < state.pages) {
    state.page += 1;
    await loadLogs();
  }
});

nodes.refreshOverview.addEventListener("click", async () => {
  await loadOverview();
});

async function bootstrap() {
  try {
    await loadOverview();
    await loadLogs();
  } catch (error) {
    nodes.detailPane.textContent = String(error);
  }
}

bootstrap();
window.setInterval(loadOverview, 10000);

/* ═══════════════════════════════════════════════════
   用户管理
   ═══════════════════════════════════════════════════ */

function maskKey(key) {
  if (!key) return "-";
  if (key.length <= 10) return key;
  return key.slice(0, 6) + "…" + key.slice(-4);
}

async function loadUsers() {
  const query = buildQuery({ q: state.userQuery, page: state.userPage });
  const payload = await fetchJSON(`/admin/api/users?${query}`);
  const { items, pagination } = payload;
  state.userPages = pagination.pages;
  nodes.userPageInfo.textContent = `第 ${pagination.page} / ${pagination.pages} 页`;
  nodes.userMeta.textContent = `共 ${pagination.total} 个用户`;
  nodes.userPrevPage.disabled = pagination.page <= 1;
  nodes.userNextPage.disabled = pagination.page >= pagination.pages;

  if (!items.length) {
    nodes.userRows.innerHTML = '<tr><td colspan="7">暂无用户。</td></tr>';
    return;
  }

  nodes.userRows.innerHTML = items.map((u) => {
    const statusBadge = u.enabled
      ? '<span class="badge ok">启用</span>'
      : '<span class="badge off">禁用</span>';
    return `
      <tr>
        <td>${escapeHtml(u.name)}</td>
        <td class="key-cell" title="${escapeHtml(u.api_key)}">${escapeHtml(maskKey(u.api_key))}</td>
        <td>${escapeHtml(u.downstream_url || "（全局）")}</td>
        <td>${statusBadge}</td>
        <td>${formatTime(u.created_at)}</td>
        <td>${escapeHtml(u.notes || "")}</td>
        <td>
          <div class="action-btns">
            <button class="ghost btn-sm" data-edit="${u.id}">编辑</button>
            <button class="ghost btn-sm btn-danger" data-del="${u.id}" data-name="${escapeHtml(u.name)}">删除</button>
          </div>
        </td>
      </tr>
    `;
  }).join("");
}

// ── 搜索 ──
let _userSearchTimer = null;
nodes.userSearch.addEventListener("input", () => {
  clearTimeout(_userSearchTimer);
  _userSearchTimer = setTimeout(() => {
    state.userQuery = nodes.userSearch.value.trim();
    state.userPage = 1;
    loadUsers();
  }, 320);
});

nodes.userPrevPage.addEventListener("click", () => {
  if (state.userPage > 1) { state.userPage--; loadUsers(); }
});
nodes.userNextPage.addEventListener("click", () => {
  if (state.userPage < state.userPages) { state.userPage++; loadUsers(); }
});

// ── 对话框操作 ──

function openDialog(title, data) {
  nodes.dialogTitle.textContent = title;
  nodes.fieldUserId.value = data.id || "";
  nodes.fieldName.value = data.name || "";
  nodes.fieldApiKey.value = data.api_key || "";
  nodes.fieldDownstreamUrl.value = data.downstream_url || "";
  nodes.fieldDownstreamApikey.value = data.downstream_apikey || "";
  nodes.fieldNotes.value = data.notes || "";
  nodes.fieldEnabled.checked = data.enabled !== undefined ? Boolean(data.enabled) : true;
  nodes.userDialog.showModal();
}

function closeDialog() {
  nodes.userDialog.close();
}

function generateKey() {
  const bytes = new Uint8Array(32);
  crypto.getRandomValues(bytes);
  const raw = btoa(String.fromCharCode(...bytes))
    .replace(/\+/g, "-").replace(/\//g, "_").replace(/=+$/, "");
  return "sk-" + raw;
}

nodes.createUserBtn.addEventListener("click", () => {
  openDialog("新建用户", {});
});

nodes.genApiKeyBtn.addEventListener("click", () => {
  nodes.fieldApiKey.value = generateKey();
});

nodes.dialogCancelBtn.addEventListener("click", closeDialog);

nodes.dialogSubmitBtn.addEventListener("click", async () => {
  const userId = nodes.fieldUserId.value;
  const body = {
    name: nodes.fieldName.value.trim(),
    api_key: nodes.fieldApiKey.value.trim(),
    downstream_url: nodes.fieldDownstreamUrl.value.trim(),
    downstream_apikey: nodes.fieldDownstreamApikey.value.trim(),
    notes: nodes.fieldNotes.value.trim(),
    enabled: nodes.fieldEnabled.checked,
  };

  if (!body.name) {
    alert("名称不能为空");
    return;
  }

  try {
    if (userId) {
      await fetchJSON(`/admin/api/users/${userId}`, {
        method: "PUT",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });
    } else {
      await fetchJSON("/admin/api/users", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(body),
      });
    }
    closeDialog();
    await loadUsers();
  } catch (err) {
    alert("保存失败: " + err.message);
  }
});

// ── 表格委托事件：编辑 / 删除 ──

nodes.userRows.addEventListener("click", async (event) => {
  const editBtn = event.target.closest("[data-edit]");
  if (editBtn) {
    try {
      const user = await fetchJSON(`/admin/api/users/${editBtn.dataset.edit}`);
      openDialog("编辑用户", user);
    } catch (err) {
      alert("加载用户失败: " + err.message);
    }
    return;
  }

  const delBtn = event.target.closest("[data-del]");
  if (delBtn) {
    const name = delBtn.dataset.name;
    if (!confirm(`确认删除用户「${name}」？此操作不可恢复。`)) return;
    try {
      await fetchJSON(`/admin/api/users/${delBtn.dataset.del}`, { method: "DELETE" });
      await loadUsers();
    } catch (err) {
      alert("删除失败: " + err.message);
    }
  }
});

// ── 页面初始化时也加载用户列表 ──
loadUsers();
