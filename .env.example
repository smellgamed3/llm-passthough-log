# ============================
# LLM 透明代理 — 环境变量配置
# ============================
# 复制本文件为 .env 并按需修改

# 应用名称
APP_NAME="LLM Passthough Log"

# 管理后台标题
ADMIN_TITLE="LLM 透明代理控制台"

# 默认管理员账号与密码（必填，仅可在 .env 中手动指定）
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# 默认下游 LLM Provider 地址
DOWNSTREAM_URL="https://api.openai.com"

# 多 Provider 路由 (JSON 格式，可选)
# 示例: {"anthropic":"https://api.anthropic.com","gemini":"https://generativelanguage.googleapis.com"}
PROVIDER_ROUTES_JSON=""

# 日志存储目录
LOG_DIR="data"

# 下游请求超时(秒)
REQUEST_TIMEOUT_SECONDS=300

# 日志写入队列最大长度
LOG_QUEUE_MAXSIZE=5000

# 管理后台默认每页条数
ADMIN_PAGE_SIZE_DEFAULT=20

# 管理后台最大每页条数
ADMIN_PAGE_SIZE_MAX=100

# Uvicorn 监听地址
HOST="0.0.0.0"

# Uvicorn 监听端口
PORT=8000

# Uvicorn worker 数量
WORKERS=1
